PORT=8787
HOST=127.0.0.1
PUBLIC_SITE_ORIGIN=https://biolecmobility.com

OPENAI_API_KEY=sk-your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

BIOLEC_SYNC_SECRET=replace-with-long-random-secret

WOOCOMMERCE_URL=https://biolecmobility.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_key
WOOCOMMERCE_CONSUMER_SECRET=cs_your_secret

# gpt-5 (full) = best conversation/reasoning; gpt-5.4-mini = cheaper + faster.
FAST_ANSWER_MODEL=gpt-5
# Products retrieved per turn (fast engine). Lower = faster + cheaper replies.
FAST_PRODUCT_MATCH_COUNT=8
# Self-service order tracking page. Mobi appends the order number to the end of
# this exact prefix (note the trailing "?"). Result e.g. .../track-order/?39556
ORDER_TRACKING_URL=https://biolecmobility.com/track-order/?

# Customer fact extraction (per-message structured profiling).
FACT_EXTRACTION_ENABLED=true
# Keep fact extraction on a small fast model (runs every turn). Do not point it
# at a reasoning model or it bottlenecks the answer.
FACT_MODEL=gpt-4o-mini

# Chat abuse protection
# Free messages an anonymous visitor can send before the name/email gate appears.
FREE_MESSAGE_LIMIT=3
# Reject chat messages longer than this many characters.
MAX_MESSAGE_LENGTH=2000
# Require the HMAC-signed WordPress proxy on /chat and /chat/register.
# Set to false only for local development without WordPress.
CHAT_REQUIRE_SIGNATURE=true
# Rate limits (per client IP and per session).
RATE_LIMIT_PER_MIN=20
RATE_LIMIT_PER_DAY=200
SESSION_RATE_LIMIT_PER_MIN=10
# Global daily cap on answer generations (OpenAI spend circuit-breaker).
DAILY_ANSWER_LIMIT=3000
# OpenAI moderation pre-check (free) on incoming messages.
MODERATION_ENABLED=true
MODERATION_MODEL=omni-moderation-latest
